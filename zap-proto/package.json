{
  "name": "zap-proto",
  "version": "1.6.0",
  "description": "ZAP — Zero-copy App Proto. The default install for the ZAP TypeScript runtime; re-exports @zap-proto/zap (zero-copy wire codec, capabilities, RPC, promise pipelining).",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "repository": { "type": "git", "url": "git+https://github.com/zap-proto/js.git", "directory": "zap-proto" },
  "homepage": "https://zap-proto.dev",
  "keywords": ["zap", "zap-proto", "zero-copy", "rpc", "capabilities", "pipelining", "wire", "mcp"],
  "dependencies": { "@zap-proto/zap": "^1.6.0" },
  "exports": {
    ".":     { "types": "./index.d.ts", "import": "./index.js", "default": "./index.js" },
    "./cap": { "types": "./cap.d.ts",   "import": "./cap.js",   "default": "./cap.js" },
    "./node":{ "types": "./node.d.ts",  "import": "./node.js",  "default": "./node.js" }
  },
  "files": ["index.js","index.d.ts","cap.js","cap.d.ts","node.js","node.d.ts","README.md"],
  "sideEffects": false
}
